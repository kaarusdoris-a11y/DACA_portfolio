    "def load(rfm):\n",
    "    logger.info(\"LOAD: Alustan...\")\n",
    "    \n",
    "    colors = {\n",
    "        'VIP Champions': '#1B2A4A',\n",
    "        'Loyal Customers': '#2DD4BF',\n",
    "        'Potential Loyalists': '#6B7280',\n",
    "        'At Risk': '#D1D5DB'\n",
    "    }\n",
    "    \n",
    "    ts = datetime.now().strftime('%Y%m%d')\n",
    "    \n",
    "    # Salvesta CSV\n",
    "    rfm.to_csv(f'rfm_report_{ts}.csv', index=False)\n",
    "    \n",
    "    # Graafik 1: Segmentide jaotus\n",
    "    segment_counts = rfm['segment'].value_counts().reset_index()\n",
    "    fig1 = px.bar(\n",
    "        segment_counts,\n",
    "        x='segment', y='count',\n",
    "        title='UrbanStyle: Kliendisegmentide jaotus (RFM)',\n",
