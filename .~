    "def run_pipeline():\n",
    "    print(\"=\" * 50)\n",
    "    print(\"  URBANSTYLE RFM PIPELINE\")\n",
    "    print(\"=\" * 50)\n",
    "    start = datetime.now()\n",
    "    \n",
    "    try:\n",
    "        orders, customers = extract()\n",
    "        rfm = transform(orders, customers)\n",
    "        load(rfm)\n",
    "        elapsed = (datetime.now() - start).total_seconds()\n",
    "        print(f\"\\n✅ PIPELINE VALMIS ({elapsed:.1f}s)\")\n",
    "        print(\"=\" * 50)\n",
    "        return True\n",
    "    except Exception as e:\n",
    "        logger.error(f\"PIPELINE EBAÕNNESTUS: {e}\")\n",
    "        return False\n",
    "\n",
    "run_pipeline()"
